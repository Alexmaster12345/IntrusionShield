# IntrusionShield default rules
# Format: action proto src_ip src_port -> dst_ip dst_port (options)
#
# Built-in signatures are always loaded from detection/signatures.py.
# Add custom rules here.

# SSH brute force — SYN-only (connection attempts, not session traffic)
alert tcp any any -> any 22 (msg:"SSH connection attempt (flags:S only)"; flags:S; sid:2000001; rev:2; severity:3)

# HTTP /admin access
alert tcp any any -> any 80 (msg:"HTTP /admin access"; content:"/admin"; nocase; sid:2000002; rev:1; severity:2)

# nmap OS fingerprint probe
alert tcp any any -> any any (msg:"Possible nmap OS fingerprint"; flags:FPU; sid:2000003; rev:1; severity:2)
